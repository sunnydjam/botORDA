# OrdaFlow Proxy Bot - Переменные окружения
# Скопируйте этот файл как .env и заполните значения

# Telegram Bot Token (получить у @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Учётные данные админ-панели
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here

# URL API сервера
ORDAFLOW_API_URL=https://your-api-url.example.com

# URL админ-панели (необязательно)
ADMIN_PANEL_URL=https://your-panel-url.com/dashboard

# ID админа для уведомлений о платежах
# Узнать свой ID: напишите боту @userinfobot или @getmyid_bot
ADMIN_CHAT_ID=your_telegram_user_id
